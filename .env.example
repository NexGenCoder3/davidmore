# ==============================================================================
# CLIENT (publishable, safe in the browser bundle)
# ==============================================================================

# Cloudflare Turnstile site key
# Create one free at https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# ==============================================================================
# SERVER (NEVER ship to client — used by /api/contact only)
# ==============================================================================

# Cloudflare Turnstile secret (NOT the site key)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# EmailJS — held server-side only
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key

# Upstash Redis — already provided by the Vercel Upstash integration
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
